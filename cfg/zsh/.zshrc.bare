# aliases
alias l="ls -l"
alias la="ls -la"

# neovim (if available, otherwise fall back to vim)
if command -v nvim &> /dev/null; then
    alias v="nvim"
    alias vim="nvim"
fi

# set vi mode
set -o vi

# Ctrl-R history search (vi insert mode otherwise binds it to redisplay)
bindkey '^R' history-incremental-search-backward
